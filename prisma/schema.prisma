generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// NextAuth related tables
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  CLIENT
  STAFF
  ADMIN
}

model User {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  phone               String?
  alt_phone           String?
  password_hash       String?
  role                Role      @default(CLIENT)
  google_id           String?
  wallet_balance      Float     @default(0)
  outstanding_balance Float     @default(0)
  is_active           Boolean   @default(true)
  account_state       String    @default("Account activated") // Imported | Portal invite pending | Invite queued | Invite sent | Invite failed | Account activated | Password configured
  imported_at         DateTime?
  portal_invited_at   DateTime?
  portal_activated_at DateTime?
  email_suppressed    Boolean   @default(false)
  email_unsubscribed  Boolean   @default(false)
  email_bounced       Boolean   @default(false)
  email_excluded      Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  pets           Pet[]
  addresses      Address[]
  clientBookings Booking[]      @relation("ClientBookings")
  staffBookings  Booking[]      @relation("StaffBookings")
  payments       Payment[]
  invoices       Invoice[]
  staffProfile   Staff?
  notifications  Notification[]

  @@index([role])
  @@index([account_state])
  @@index([email_suppressed])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pet {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  owner_id               String    @db.ObjectId
  name                   String
  type                   String // Dog, Cat, Bird, Other
  breed                  String?
  gender                 String?
  dob                    DateTime?
  weight                 Float?
  coat_type              String?
  size                   String? // Small, Medium, Large, Giant
  aggression_level       Int?      @default(1) // 1-10
  profile_photo          String?
  photos_array           Json? // Array of strings (URLs)
  neutered               Boolean?  @default(false)
  special_occasion       String?
  special_occasion_date  DateTime?
  microchip_number       String?
  adoption_status        String?
  social_handle          String?
  consent_photos         Boolean?  @default(false)
  dietary_preference     String?
  allergies              String?
  preferences            String?
  walk_schedule_1        String?
  walk_schedule_2        String?
  walk_schedule_3        String?
  local_guardian_name    String?
  local_guardian_contact String?
  tc_accepted            Boolean?  @default(true)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  owner        User             @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  medical      PetMedical?
  bookings     Booking[]
  vaccinations PetVaccination[]

  birthday_reminder_enabled Boolean? @default(true)
  dob_is_estimated          Boolean? @default(false)
}

model PetMedical {
  id                               String    @id @default(auto()) @map("_id") @db.ObjectId
  pet_id                           String    @unique @db.ObjectId
  vaccination_status               String? // Vaccinated, Not Vaccinated, Partial
  anti_rabies_date                 DateTime?
  dhppl_date                       DateTime?
  corona_date                      DateTime?
  kennel_cough_date                DateTime?
  deworming_date                   DateTime?
  tick_prevention                  Boolean?  @default(false)
  tick_prevention_date             DateTime?
  tick_method                      String?
  ongoing_medication               Boolean?  @default(false)
  medication_detail                String?
  illness_history                  String?
  vaccination_certificate_asset_id String?   @db.ObjectId
  vaccination_certificate_path     String?
  last_heat_month                  Int?
  last_heat_year                   Int?
  vet_name                         String?
  vet_contact                      String?

  pet Pet @relation(fields: [pet_id], references: [id], onDelete: Cascade)
}

model Address {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String  @db.ObjectId
  label      String? // Home, Work, Other
  line1      String
  city       String
  state      String
  pincode    String
  phone      String?
  lat        Float?
  lng        Float?
  is_default Boolean @default(false)

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Service {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  category           String // Grooming, Boarding
  service_group      String?
  breed_size         String?
  coat_type          String?
  session_count      Int?
  display_order      Int      @default(0)
  description_short  String?
  description_long   String?
  price              Float
  discounted_price   Float?
  slot_duration_mins Int      @default(60)
  max_slots_per_day  Int?
  is_active          Boolean  @default(true)
  is_coming_soon     Boolean  @default(false)
  is_bestseller      Boolean  @default(false)
  free_services_json Json? // Array of strings
  images_json        Json? // Array of strings (URLs)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  addons   Addon[]
  bookings Booking[]
}

model Addon {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  service_id  String  @db.ObjectId
  name        String
  description String?
  price       Float
  is_active   Boolean @default(true)

  service Service @relation(fields: [service_id], references: [id], onDelete: Cascade)
}

model Booking {
  id                       String    @id @default(auto()) @map("_id") @db.ObjectId
  booking_id               String    @unique // Human-readable e.g. BKG-1029
  client_id                String    @db.ObjectId
  pet_id                   String    @db.ObjectId
  service_id               String    @db.ObjectId
  staff_id                 String?   @db.ObjectId
  address_id               String?   @db.ObjectId
  addons_json              Json? // Array of addon objects
  slot_date                DateTime
  slot_time                String // e.g. "10:00 AM"
  status                   String    @default("Pending") // Pending, Confirmed, In Progress, Completed, Cancelled
  payment_status           String    @default("Pending") // Pending, Paid, Refunded
  notes                    String?
  internal_notes           String?
  after_photos_json        Json? // Array of strings (URLs)
  boarding_type            String?
  check_in_date            DateTime?
  check_out_date           DateTime?
  check_in_time            String?
  check_out_time           String?
  check_in_slot            String?
  check_out_slot           String?
  weight                   Float?
  check_out_weight         Float?
  meal_type                String?
  kennel                   String?
  final_amount             Float?
  discount_type            String? // PERCENT or FLAT
  discount_value           Float? // 10 => 10% when PERCENT, or Rs. 10 when FLAT
  discount_amount          Float? // resolved rupee value of the discount, computed server-side
  discount_reason          String?
  discount_by              String?   @db.ObjectId // admin/staff user who applied it
  // Boarding stay extension. A client's request parks here as "Requested" until an
  // admin/staff approves it; admin/staff extensions are applied straight away.
  extension_status         String? // Requested, Approved, Rejected
  extension_check_out_date DateTime?
  extension_check_out_time String?
  extension_extra_amount   Float? // additional charge the extension adds
  extension_note           String?
  extension_requested_by   String?   @db.ObjectId
  extension_requested_at   DateTime?
  extension_decided_at     DateTime?
  late_checkout_fees       Float?
  refund_amount            Float?
  refund_reason            String?
  companion_name           String?
  companion_phone          String?
  end_time                 String?
  staff_name               String?
  services_json            Json?
  documents_json           Json?
  details_completed        Boolean   @default(false)
  google_event_id          String?
  expiry_locked            Boolean   @default(false) // true once an admin/staff manually sets status; blocks auto-expiry from overwriting it
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  client   User      @relation("ClientBookings", fields: [client_id], references: [id])
  staff    User?     @relation("StaffBookings", fields: [staff_id], references: [id])
  pet      Pet       @relation(fields: [pet_id], references: [id])
  service  Service   @relation(fields: [service_id], references: [id])
  address  Address?  @relation(fields: [address_id], references: [id])
  payments Payment[]
  invoices Invoice[]
}

model Payment {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  booking_id          String?  @db.ObjectId
  client_id           String   @db.ObjectId
  invoice_id          String?
  invoice_type        String?
  amount              Float
  mode                String // Cash, Online, Wallet
  source              String? // Razorpay, Manual
  razorpay_order_id   String?
  razorpay_payment_id String?
  transaction_id      String?  @unique
  status              String   @default("Pending") // Pending, Success, Failed, Refunded
  parent_phone        String?
  created_at          DateTime @default(now())

  booking Booking? @relation(fields: [booking_id], references: [id])
  client  User     @relation(fields: [client_id], references: [id])
}

model Invoice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  invoice_id      String   @unique // Human-readable
  booking_id      String?  @db.ObjectId
  client_id       String   @db.ObjectId
  line_items_json Json // Array of line items {desc, qty, rate, amount}
  subtotal        Float
  tax             Float    @default(0)
  total           Float
  status          String   @default("Pending") // Pending, Paid
  pdf_path        String?
  created_at      DateTime @default(now())

  booking Booking? @relation(fields: [booking_id], references: [id])
  client  User     @relation(fields: [client_id], references: [id])
}

model Staff {
  id                 String @id @default(auto()) @map("_id") @db.ObjectId
  user_id            String @unique @db.ObjectId
  role               String // Groomer, Walker, Trainer, Receptionist, Admin
  services_json      Json? // Array of service categories they can handle
  working_hours_json Json?
  leave_dates_json   Json?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Expense {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  date            DateTime
  category        String // Supplies, Staff, Marketing, Utilities, Other
  description     String
  amount          Float
  mode            String // Cash, Bank, UPI
  reference       String?
  attachment_path String?
  created_by      String   @db.ObjectId
  created_at      DateTime @default(now())
}

model Notification {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String    @db.ObjectId
  channel    String // Email, SMS, Both
  type       String // Reminder, Confirmation, etc.
  subject    String?
  body       String
  status     String    @default("Pending") // Pending, Sent, Failed
  sent_at    DateTime?
  created_at DateTime  @default(now())

  // Optional context for pet birthday / vaccination reminders. All backward-compatible.
  pet_id              String?   @db.ObjectId
  vaccination_id      String?   @db.ObjectId
  template_key        String?
  recipient           String?
  provider_message_id String?
  error_message       String?
  scheduled_for       DateTime?
  attempt_count       Int?      @default(0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([pet_id])
  @@index([type])
}

model Asset {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  filename      String
  original_name String
  path          String
  category      String // Services, Hero, Testimonials, Staff, General
  document_type String?
  client_id     String?  @db.ObjectId
  pet_id        String?  @db.ObjectId
  booking_id    String?  @db.ObjectId
  notes         String?
  uploaded_by   String?  @db.ObjectId
  is_verified   Boolean  @default(false)
  created_at    DateTime @default(now())
}

model OldDataImportJob {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  source_path   String?
  status        String   @default("Pending")
  mode          String   @default("Preview")
  summary_json  Json?
  report_json   Json?
  error_message String?
  created_by    String?  @db.ObjectId
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model OldClientHistory {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  client_key            String   @unique
  client_id             String?  @db.ObjectId
  client_record_id      String?  @db.ObjectId
  client_name           String?
  phone                 String?
  email                 String?
  address               String?
  pet_names_json        Json?
  client_details_json   Json?
  pet_details_json      Json?
  health_details_json   Json?
  booking_history_json  Json?
  boarding_history_json Json?
  grooming_history_json Json?
  invoice_history_json  Json?
  payment_history_json  Json?
  timeline_json         Json?
  summary_json          Json?
  raw_sources_json      Json?
  duplicate_notes_json  Json?
  source                String   @default("Old Data Import")
  import_job_id         String?  @db.ObjectId
  import_date           DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@index([phone])
  @@index([email])
  @@index([client_name])
}

model ServiceArea {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  pincode    String   @unique
  city       String
  area_name  String?
  state      String   @default("Gujarat")
  country    String   @default("India")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model AppSetting {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  key        String   @unique
  value      Json
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())
}

model Testimonial {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  pet_name   String?
  pet_breed  String?
  rating     Int      @default(5)
  text       String
  image      String?
  is_active  Boolean  @default(true)
  order      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ClientRecord {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  pet_id_number             Int? // Pet ID from CSV
  name                      String
  phone                     String
  email                     String?
  pet_name                  String?
  pet_type                  String?
  breed                     String?
  gender                    String?
  pet_birthday              String?
  address                   String?
  latest_booking_date       String?
  onboarding_date           String?
  number_of_bookings        Int?     @default(0)
  number_of_sessions        Int?     @default(0)
  client_tags               String?
  home_outlet               String?
  coat                      String?
  breed_size                String?
  weight_kg                 Float?
  anti_rabies               String?
  dhppil                    String?
  corona                    String?
  kennel_cough              String?
  local_guardian_name       String?
  local_guardian_contact    String?
  status                    String?  @default("Active")
  archive_reason            String?
  pet_social_media          String?
  consent_photos            String?
  special_occasion          String?
  special_occasion_date     String?
  microchip_number          String?
  adoption_status           String?
  neutered_or_spayed        String?
  last_heat_month           String?
  last_heat_year            String?
  first_walk_schedule       String?
  second_walk_schedule      String?
  third_walk_schedule       String?
  dietary_preference        String?
  additional_meals          String?
  preferences_or_allergies  String?
  vaccination_status        String?
  tick_prevention           String?
  last_tick_prevention_date String?
  tick_prevention_method    String?
  ongoing_medication        String?
  medication_detail         String?
  major_illness_history     String?
  deworming_date            String?
  veterinarian_name         String?
  veterinarian_contact      String?
  tc_accepted               String?
  wallet_balance            Float?   @default(0)
  outstanding_balance       Float?   @default(0)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Pet Birthday & Vaccination Reminder System
// ─────────────────────────────────────────────────────────────────────────────

/// One vaccination/treatment cycle for a pet. The authoritative source of the
/// *next due date*. Administered dates from the legacy PetMedical model are
/// backfilled into these records by scripts/migrate-pet-vaccinations.ts.
model PetVaccination {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  pet_id               String    @db.ObjectId
  vaccine_type_id      String?   @db.ObjectId
  vaccine_type         String // one of VACCINE_TYPES keys (see lib/reminders/vaccine-config)
  type_display_name    String?
  category             String? // vaccine | deworming | parasite_prevention | custom_treatment
  custom_vaccine_name  String? // required when vaccine_type === "custom"
  administered_date    DateTime?
  next_due_date        DateTime
  recommended_interval_months Int?
  reminder_enabled     Boolean   @default(true)
  reminder_days_json   Json? // optional per-record override of the global schedule (number[])
  reminder_recipient   String?
  notes                String?
  vet_name             String?
  vet_contact          String?
  provider_name        String?
  administered_by      String?
  dose_number          String?
  batch_lot_number     String?
  certificate_asset_id String?   @db.ObjectId
  certificate_path     String?
  status               String    @default("Upcoming") // derived on read; stored as a hint only
  source               String    @default("staff") // customer | staff | admin | imported | migrated
  verification_status  String    @default("Verified") // Submitted | Verified | Rejected | Needs clarification
  legacy_value         String?
  legacy_review_required Boolean @default(false)
  archived_at          DateTime?
  completed_at         DateTime?
  created_by           String?   @db.ObjectId
  updated_by           String?   @db.ObjectId
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  pet Pet @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@index([pet_id])
  @@index([vaccine_type_id])
  @@index([next_due_date])
  @@index([reminder_enabled])
  @@index([archived_at])
  @@index([verification_status])
}

model VaccineTreatmentType {
  id                              String   @id @default(auto()) @map("_id") @db.ObjectId
  key                             String   @unique
  display_name                    String
  normalized_name                 String   @unique
  category                        String
  default_interval_months         Int?
  is_active                       Boolean  @default(true)
  archived_at                     DateTime?
  display_order                   Int      @default(0)
  legacy_aliases_json             Json?
  created_by                      String?  @db.ObjectId
  updated_by                      String?  @db.ObjectId
  created_at                      DateTime @default(now())
  updated_at                      DateTime @updatedAt

  @@index([category])
  @@index([is_active])
  @@index([display_order])
}

/// Idempotent ledger of every reminder we attempt to deliver. The unique
/// reminder_key is reserved atomically before an email is sent so the same
/// reminder can never be sent twice, even under concurrent cron runs.
model ReminderDelivery {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  reminder_key        String    @unique
  user_id             String?   @db.ObjectId
  pet_id              String?   @db.ObjectId
  vaccination_id      String?   @db.ObjectId
  reminder_type       String // birthday | birthday_greeting | vaccination_due_soon | ...
  channel             String    @default("Email")
  scheduled_for       DateTime
  recipient           String?
  subject             String?
  status              String    @default("Pending") // Pending, Processing, Sent, Failed, Skipped
  provider_message_id String?
  error_message       String?
  attempt_count       Int       @default(0)
  sent_at             DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([scheduled_for])
  @@index([status])
  @@index([pet_id])
}

model EmailLog {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  email_type          String
  recipient           String
  subject             String?
  related_user_id     String?   @db.ObjectId
  related_pet_id      String?   @db.ObjectId
  related_booking_id  String?   @db.ObjectId
  related_campaign_id String?   @db.ObjectId
  status              String    @default("Queued") // Queued | Sent | Failed | Skipped
  queued_at           DateTime  @default(now())
  attempted_at        DateTime?
  sent_at             DateTime?
  provider_message_id String?
  attempt_count       Int       @default(0)
  failure_reason      String?
  retry_eligible      Boolean   @default(false)
  idempotency_key     String?   @unique
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([email_type])
  @@index([recipient])
  @@index([status])
  @@index([related_user_id])
  @@index([related_campaign_id])
}

model EmailCampaign {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  campaign_type   String
  status          String    @default("Draft") // Draft | Running | Paused | Stopped | Completed
  started_at      DateTime?
  completed_at    DateTime?
  paused_at       DateTime?
  stopped_at      DateTime?
  daily_cap       Int?
  reserved_quota  Int       @default(50)
  total_eligible  Int       @default(0)
  queued          Int       @default(0)
  sent            Int       @default(0)
  delivered       Int       @default(0)
  failed          Int       @default(0)
  skipped         Int       @default(0)
  activated       Int       @default(0)
  created_by      String?   @db.ObjectId
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([campaign_type])
  @@index([status])
}

model EmailCampaignRecipient {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  campaign_id         String    @db.ObjectId
  campaign_type       String
  customer_id         String    @db.ObjectId
  email               String
  status              String    @default("Queued") // Queued | Processing | Sent | Failed | Skipped | Activated
  queued_at           DateTime?
  attempted_at        DateTime?
  sent_at             DateTime?
  provider_message_id String?
  attempt_count       Int       @default(0)
  last_error          String?
  skipped_reason      String?
  activation_status   String?
  token_reference     String?
  next_attempt_at     DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([campaign_id])
  @@index([status])
  @@index([next_attempt_at])
  @@index([customer_id])
  @@unique([campaign_type, customer_id])
}
