<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OnePWS Future Control Room | Automation Expo 2026</title>
  <meta name="description" content="Visit OnePWS at Automation Expo 2026, BEC Mumbai, 22-25 July 2026. Experience a live future control room for industrial automation, smart manufacturing, AI monitoring, digital twin and OT cybersecurity.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #000;
      --panel: #080808;
      --panel-2: #111;
      --ink: #fff;
      --muted: #a8a8a8;
      --soft: #d9d9d9;
      --red: #EA2D2D;
      --red-2: #b91f1f;
      --line: rgba(255,255,255,.12);
      --line-red: rgba(234,45,45,.42);
      --blue: #36a9ff;
      --green: #5ad69b;
      --radius: 8px;

      --shadow: 0 24px 70px rgba(0,0,0,.55);
    }

    * { box-sizing: border-box; }
    html {
      width: 100%;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }
    body {
      width: 100%;
      margin: 0;
      font-family: "Be Vietnam Pro", Arial, sans-serif;
      font-size: 14px;
      line-height: 1.65;
      color: var(--ink);
      background:
        radial-gradient(circle at 18% 8%, rgba(234,45,45,.16), transparent 28rem),
        linear-gradient(180deg, #050505 0%, #000 40%, #030303 100%);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button, input, textarea { font: inherit; }
    .container { width: 90%; max-width: var(--max); margin: 0 auto; }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--red);
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .eyebrow::before {
      content: "";
      width: 30px;
      height: 2px;
      background: var(--red);
      box-shadow: 0 0 18px rgba(234,45,45,.9);
    }
    .section { padding: 10px 0 72px; position: relative; }
    section[id] { scroll-margin-top: 112px; }
    .section-head {
      display: grid;
      grid-template-columns: minmax(0, .85fr) minmax(260px, .55fr);
      gap: 34px;
      align-items: end;
      margin-bottom: 34px;
    }
    h1, h2, h3, p { margin: 0; }
    h1 {
      margin-top: 14px;
      font-size: 2.75rem;
      line-height: 1.06;
      letter-spacing: 0;
      max-width: 820px;
      overflow-wrap: anywhere;
    }
    h2 {
      margin-top: 12px;
      font-size: 2.05rem;
      line-height: 1.18;
      letter-spacing: 0;
      max-width: 760px;
    }
    h3 { font-size: 1rem; line-height: 1.3; letter-spacing: 0; }
    .lead { color: var(--soft); max-width: 720px; }
    .muted { color: var(--muted); }
    .red { color: var(--red); }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 42px;
      padding: 11px 16px;
      border-radius: 6px;
      border: 1px solid transparent;
      font-size: .82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .03em;
      transition: transform .2s ease, border-color .2s ease, background .2s ease;
      white-space: nowrap;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn-primary { background: var(--red); color: #fff; box-shadow: 0 14px 34px rgba(234,45,45,.24); }
    .btn-secondary { border-color: rgba(255,255,255,.22); background: rgba(255,255,255,.05); color: #fff; }
    .btn-register {
      min-height: 36px;
      padding: 9px 16px;
      border-color: #fff;
      background: #fff !important;
      color: var(--red);
      font-size: .68rem;
      box-shadow: none;
    }
    .btn svg { width: 16px; height: 16px; flex: 0 0 auto; }

    .nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 50;
      background: rgba(0,0,0,.78);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--line);
    }
    .nav-inner {
      position: relative;
      min-height: 84px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .brand { display: inline-flex; align-items: center; gap: 14px; min-width: 0; }
    .brand img:first-child { width: 180px; height: auto; }
    .brand img:last-child { width: 116px; height: auto; }
    .nav-links { display: flex; align-items: center; gap: 24px; color: #d7d7d7; font-size: .82rem; font-weight: 700; }
    .nav-links a:hover { color: #fff; }
    .nav-links a {
      position: relative;
      padding-bottom: 3px;
      transition: color .2s;
    }
    .nav-links a.is-active { color: #fff; }
    .nav-links a.is-active::after {
      content: "";
      position: absolute; bottom: -3px; left: 0; right: 0;
      height: 2px; background: var(--red); border-radius: 2px;
    }
    .nav-actions { display: flex; align-items: center; gap: 12px; flex: 0 0 auto; }
    .nav-stats {
      display: grid;
      grid-template-columns: repeat(4, max-content);
      gap: 28px;
      align-items: center;
      color: #fff;
    }
    .nav-stat strong {
      display: block;
      color: var(--red);
      font-size: 1.45rem;
      line-height: 1;
      letter-spacing: .02em;
    }
    .nav-stat span {
      display: block;
      margin-top: 4px;
      color: #f1f1f1;
      font-size: .62rem;
      font-weight: 800;
      line-height: 1.15;
      text-transform: uppercase;
    }
    .event-status {
      min-width: 220px;
      padding: 9px 12px;
      border: 1px solid rgba(234,45,45,.42);
      border-radius: 8px;
      background: rgba(234,45,45,.08);
    }
    .event-status-label {
      display: block;
      color: var(--red);
      font-size: .62rem;
      font-weight: 800;
      letter-spacing: .08em;
      line-height: 1;
      text-transform: uppercase;
    }
    .countdown-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 6px;
      margin-top: 7px;
    }
    .countdown-grid span {
      display: grid;
      gap: 2px;
      text-align: center;
      color: #fff;
      font-size: .9rem;
      font-weight: 800;
      line-height: 1;
    }
    .countdown-grid small {
      color: var(--muted);
      font-size: .52rem;
      font-weight: 700;
      letter-spacing: .05em;
      text-transform: uppercase;
    }
    .event-status.is-live,
    .event-status.is-expired {
      min-width: 132px;
      text-align: center;
    }
    .event-status.is-live .countdown-grid,
    .event-status.is-expired .countdown-grid { display: none; }
    .event-status.is-live .event-status-label,
    .event-status.is-expired .event-status-label {
      font-size: .85rem;
      line-height: 1.2;
    }
    .event-status.is-live {
      border-color: rgba(90,214,155,.58);
      background: rgba(90,214,155,.1);
    }
    .event-status.is-live .event-status-label { color: var(--green); }
    .event-status.is-expired {
      border-color: rgba(168,168,168,.35);
      background: rgba(168,168,168,.08);
    }
    .event-status.is-expired .event-status-label { color: var(--muted); }
    .live-pulse-dot {
      display: none;
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--green); flex-shrink: 0;
      animation: livePulse 1.6s ease-out infinite;
    }
    .event-status.is-live .live-pulse-dot { display: inline-block; }
    @keyframes livePulse {
      0%  { box-shadow: 0 0 0 0   rgba(90,214,155,.7); }
      70% { box-shadow: 0 0 0 8px rgba(90,214,155,0); }
      100%{ box-shadow: 0 0 0 0   rgba(90,214,155,0); }
    }
    .showcase-live-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--red); flex-shrink: 0;
      animation: showcasePulse 2s ease-out infinite;
    }
    @keyframes showcasePulse {
      0%  { box-shadow: 0 0 0 0    rgba(234,45,45,.7); }
      70% { box-shadow: 0 0 0 10px rgba(234,45,45,0); }
      100%{ box-shadow: 0 0 0 0    rgba(234,45,45,0); }
    }
    /* Showcase stats strip — Exact Automation Expo 2026 card style */
    .showcase-stat-strip {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
      margin: 0 0 32px;
    }
    .showcase-stat-strip-item {
      background: #1a1a1a;
      border-radius: 16px;
      padding: 28px 16px 24px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      border: 1px solid rgba(255,255,255,.06);
    }
    .showcase-stat-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      flex-shrink: 0;
    }
    .showcase-stat-icon svg {
      width: 52px;
      height: 52px;
      stroke: #fff;
      fill: none;
      stroke-width: 1.2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .showcase-stat-strip-item strong {
      display: block;
      font-size: 1.95rem;
      font-weight: 800;
      color: #fff;
      line-height: 1;
      letter-spacing: -.02em;
    }
    .showcase-stat-strip-item span {
      display: block;
      font-size: .72rem;
      color: #888;
      font-weight: 500;
      letter-spacing: .01em;
      margin-top: -8px;
      line-height: 1.4;
    }
    .menu-toggle {
      display: none;
      width: 42px;
      height: 42px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.05);
      color: #fff;
      border-radius: 6px;
    }
    .menu-toggle svg { width: 20px; height: 20px; margin: auto; display: block; }
    .menu-toggle .icon-close { display: none; }
    .mobile-open .menu-toggle .icon-menu { display: none; }
    .mobile-open .menu-toggle .icon-close { display: block; }

    .hero {
      min-height: 860px;
      padding: 124px 0 42px;
      display: grid;
      align-items: center;
      isolation: isolate;
      position: relative;
      overflow: hidden;
      background: #000;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      background:
        linear-gradient(90deg, rgba(0,0,0,.92) 0%, rgba(0,0,0,.7) 38%, rgba(0,0,0,.28) 70%, rgba(0,0,0,.12) 100%),
        linear-gradient(180deg, rgba(0,0,0,.42), rgba(0,0,0,.25) 46%, rgba(0,0,0,.7));
      pointer-events: none;
    }
    .hero-slider {
      position: absolute;
      inset: 0;
      z-index: -1;
    }
    .hero-slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      background-position: center;
      background-size: cover;
      background-repeat: no-repeat;
      animation: heroFade 12s infinite;
    }
    .hero-slide:nth-child(2) { animation-delay: 6s; }
    @keyframes heroFade {
      0%, 43% { opacity: 1; }
      50%, 93% { opacity: 0; }
      100% { opacity: 1; }
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, .76fr);
      gap: 38px;
      align-items: center;
    }
    .hero-copy {
      position: relative;
      z-index: 2;
      text-shadow: 0 2px 18px rgba(0,0,0,.7);
    }
    .hero-copy h1 span { color: var(--red); }
    .hero-copy .lead { margin-top: 18px; max-width: 680px; }
    .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }
    .hero-meta {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-top: 30px;
      max-width: 760px;
    }
    .meta-tile {
      border: 1px solid var(--line-red);
      background: linear-gradient(180deg, rgba(234,45,45,.12), rgba(255,255,255,.04));
      border-radius: var(--radius);
      padding: 13px;
      min-height: 88px;
    }
    .meta-tile img { width: 24px; height: 24px; margin-bottom: 10px; }
    .meta-tile strong { display: block; font-size: .95rem; line-height: 1.15; }
    .meta-tile span { color: var(--muted); font-size: .72rem; text-transform: uppercase; letter-spacing: .04em; }
    .ticker {
      margin-top: 10px;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: rgba(255,255,255,.035);
      overflow: hidden;
    }
    @keyframes dividerDash { to { stroke-dashoffset: -36; } }
    .ticker-track {
      width: max-content;
      display: flex;
      gap: 36px;
      align-items: center;
      padding: 13px 0;
      animation: move 24s linear infinite;
      color: #e7e7e7;
      font-size: .78rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .06em;
    }
    .ticker-track span { color: var(--red); }
    @keyframes move { to { transform: translateX(-50%); } }

    .facts {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }
    .fact, .scenario, .capability, .visit-step, .showcase-item, .presence-chip, .contact-panel {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
    }
    .fact {
      min-height: 132px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow: hidden;
      position: relative;
    }
    .fact::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 2px;
      background: linear-gradient(90deg, var(--red), transparent);
    }
    .fact img { width: 28px; height: 28px; }
    .fact small { color: var(--muted); text-transform: uppercase; letter-spacing: .06em; font-weight: 700; }
    .fact strong { display: block; margin-top: 8px; font-size: 1rem; line-height: 1.25; }

    .proof-band {
      padding: 42px 0 54px;
      background:
        linear-gradient(180deg, rgba(234,45,45,.08), transparent),
        radial-gradient(circle at 50% 0, rgba(234,45,45,.2), transparent 28rem);
      border-block: 1px solid rgba(234,45,45,.2);
    }
    .proof-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      text-align: center;
    }
    .proof-grid > div {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .proof-grid strong { display: block; color: var(--red); font-size: 1.8rem; line-height: 1; }
    .proof-grid span { display: block; color: var(--soft); font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; text-align: center; }

    .scenarios {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }
    .scenario {
      min-height: 220px;
      padding: 22px;
      position: relative;
      overflow: hidden;
    }
    .scenario::before {
      content: attr(data-no);
      color: rgba(234,45,45,.9);
      font-size: 2.25rem;
      line-height: 1;
      font-weight: 800;
      display: block;
      margin-bottom: 18px;
    }
    .scenario p { color: var(--muted); margin-top: 10px; }
    .scenario::after {
      content: "";
      position: absolute;
      right: -24px;
      bottom: -24px;
      width: 130px;
      height: 130px;
      border: 1px solid rgba(234,45,45,.22);
      transform: rotate(35deg);
    }

    .showcase-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }
    .showcase-item { overflow: hidden; background: #070707; }
    .showcase-item img {
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      border-bottom: 1px solid var(--line);
    }
    .showcase-item div { padding: 16px; }
    .showcase-item h3 { text-transform: uppercase; font-size: .82rem; }
    .showcase-item p { color: var(--muted); margin-top: 8px; font-size: .82rem; }

    .event-schedule {
      background: #000;
    }
    .schedule-stack {
      display: grid;
      gap: 30px;
      width: 90%;
      max-width: var(--max);
      margin-inline: auto;
      padding-inline: 0;
    }
    .schedule-title h2,
    .conference-head h2 {
      font-size: 2.3rem;
      line-height: 1.12;
    }
    .day-list {
      display: grid;
      gap: 28px;
      margin-top: 34px;
    }
    .day-item {
      display: grid;
      grid-template-columns: 48px minmax(0, 1fr);
      gap: 16px;
      align-items: start;
    }
    .day-marker {
      display: grid;
      justify-items: center;
      gap: 10px;
    }
    .day-icon {
      width: 38px;
      height: 38px;
      display: grid;
      place-items: center;
      border: 1px solid var(--red);
      border-radius: 50%;
      background: rgba(234,45,45,.08);
      color: var(--red);
      box-shadow: 0 0 26px rgba(234,45,45,.14);
    }
    .day-icon svg {
      width: 17px;
      height: 17px;
    }
    .day-icon-divider {
      width: 46px;
      height: 78px;
      color: var(--red);
      opacity: .86;
      overflow: hidden;
    }
    .day-icon-divider svg {
      display: block;
      width: 100%;
      height: 100%;
    }
    .day-icon-divider path {
      stroke-dasharray: 10 12;
      animation: dividerDash 1.4s linear infinite;
    }
    .day-kicker {
      color: var(--red);
      font-size: .72rem;
      font-weight: 800;
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }
    .day-item h3 {
      font-size: 1rem;
      margin-bottom: 8px;
    }
    .day-lines {
      display: grid;
      max-width: none;
      border-top: 1px solid rgba(255,255,255,.08);
    }
    .day-line {
      display: grid;
      grid-template-columns: 112px minmax(0, 1fr);
      gap: 14px;
      padding: 7px 0;
      border-bottom: 1px solid rgba(255,255,255,.08);
      color: #fff;
      font-size: .83rem;
      line-height: 1.35;
    }
    .day-line strong {
      color: #fff;
      white-space: nowrap;
    }

    .conference-table-wrap {
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
      background: #050505;
    }
    .conference-table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      font-size: .82rem;
    }
    .conference-table th {
      background: var(--red);
      color: #fff;
      text-align: left;
      padding: 14px 16px;
      font-size: .68rem;
      letter-spacing: .04em;
      text-transform: uppercase;
    }
    .conference-table td {
      padding: 14px 16px;
      vertical-align: top;
      border-top: 1px solid rgba(255,255,255,.08);
      border-right: 1px solid rgba(255,255,255,.14);
      background: #090909;
    }
    .conference-table tr:nth-child(even) td { background: #040404; }
    .conference-table td:last-child,
    .conference-table th:last-child { border-right: 0; }
    .conference-table strong { display: block; font-size: .86rem; }
    .conference-table small {
      display: block;
      color: #e4e4e4;
      margin-top: 2px;
      line-height: 1.35;
    }
    .workshop-card {
      margin-top: 66px;
      min-height: 350px;
      padding: 34px;
      border: 1px solid rgba(234,45,45,.58);
      border-radius: 8px;
      background:
        linear-gradient(105deg, rgba(234,45,45,.16), rgba(0,0,0,.96) 48%),
        #050505;
      box-shadow: inset 0 0 35px rgba(234,45,45,.12);
      position: relative;
      overflow: hidden;
    }
    .workshop-card::after {
      content: "";
      position: absolute;
      inset: auto -120px -190px auto;
      width: 520px;
      height: 320px;
      background: radial-gradient(circle, rgba(234,45,45,.24), transparent 66%);
      pointer-events: none;
    }
    .workshop-card h2 {
      max-width: 720px;
      font-size: 1.95rem;
    }
    .workshop-card .lead {
      max-width: 720px;
      margin-top: 14px;
      color: #fff;
      font-weight: 600;
    }
    .workshop-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 26px;
    }
    .workshop-pills span {
      padding: 10px 14px;
      border: 1px solid rgba(234,45,45,.35);
      border-radius: 999px;
      background: rgba(234,45,45,.09);
      color: #fff;
      font-size: .76rem;
      font-weight: 700;
    }

    .showcase-reference {
      padding: 72px 0;
      background: #000;
    }
    .showcase-live {
      border-top: 1px solid rgba(255,255,255,.08);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .showcase-header {
      max-width: 1120px;
      margin: 0 auto 32px;
      text-align: center;
    }
    .pws-brand { text-transform: none !important; font-style: normal; }
    .showcase-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 44px;
      padding: 10px 20px;
      border: 1px solid var(--red);
      border-radius: 6px;
      color: #fff;
      background: rgba(234,45,45,.28);
      box-shadow: 0 0 30px rgba(234,45,45,.18);
      font-size: 1.26rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .02em;
    }
    .showcase-header h2 {
      max-width: none;
      margin-top: 14px;
      font-size: 2rem;
      line-height: 1.15;
      text-transform: uppercase;
    }
    .showcase-header p {
      max-width: 1080px;
      margin: 12px auto 0;
      color: #fff;
      font-size: .78rem;
      font-weight: 600;
      line-height: 1.35;
    }
    .showcase-feature-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
      margin-bottom: 18px;
    }
    .showcase-feature {
      min-height: 128px;
      display: grid;
      grid-template-columns: 82px minmax(0, .78fr) minmax(120px, .72fr);
      gap: 18px;
      align-items: center;
      border: 1px solid rgba(234,45,45,.65);
      border-radius: 8px;
      background:
        linear-gradient(90deg, rgba(234,45,45,.18), rgba(255,255,255,.03) 42%, rgba(0,0,0,.1)),
        #080808;
      box-shadow: inset 0 0 24px rgba(234,45,45,.18), 0 0 22px rgba(234,45,45,.1);
      overflow: hidden;
      padding: 18px 22px;
    }
    .showcase-feature strong {
      color: var(--red);
      font-size: 3.25rem;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0;
    }
    .showcase-feature h3 {
      font-size: 1.28rem;
      font-weight: 500;
      color: #f0f0f0;
    }
    .showcase-feature img {
      width: 100%;
      height: 100px;
      object-fit: cover;
      border-radius: 6px;
      opacity: .82;
      filter: saturate(1.1) contrast(1.08);
    }
    .why-panel {
      position: relative;
      padding: 64px 0 40px;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      text-align: center;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(0,0,0,.1), rgba(0,0,0,.92)),
        radial-gradient(circle at 50% 0, rgba(234,45,45,.18), transparent 36rem);
    }
    .why-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(234,45,45,.35) 1px, transparent 1.5px);
      background-size: 20px 20px;
      transform: perspective(520px) rotateX(58deg) translateY(-150px);
      transform-origin: top;
      opacity: .38;
      pointer-events: none;
    }
    .why-panel > .container { position: relative; z-index: 1; }
    .tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 10px 18px;
      border: 1px solid var(--red);
      border-radius: 6px;
      color: #fff;
      background: rgba(234,45,45,.28);
      box-shadow: 0 0 30px rgba(234,45,45,.18);
      font-size: 1.26rem;
      font-weight: 800;
      text-transform: uppercase;
    }
    .why-panel h2 {
      max-width: none;
      margin-inline: auto;
      font-size: 1.15rem;
      text-transform: uppercase;
      color: var(--soft);
    }
    .why-panel .lead {
      max-width: 920px;
      margin: 10px auto 0;
      color: #fff;
      font-size: .78rem;
      font-weight: 600;
    }
    .scale-stats {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 20px;
      margin-top: 36px;
    }
    .scale-stats strong {
      display: block;
      color: var(--red);
      font-size: 1.9rem;
      line-height: 1;
    }
    .scale-stats span {
      display: block;
      margin-top: 8px;
      color: #fff;
      font-size: .76rem;
      line-height: 1.3;
      text-transform: uppercase;
    }
    .elementor-carousel {
      margin-top: 34px;
      position: relative;
    }
    .carousel-viewport {
      overflow: hidden;
      border-radius: 8px;
      margin-inline: 10px;
    }
    .carousel-track {
      display: flex;
      transition: transform .52s ease;
      will-change: transform;
    }
    .carousel-slide {
      flex: 0 0 33.333%;
      padding: 0 10px;
    }
    .carousel-card {
      height: 100%;
      min-height: 300px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 8px;
      background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.025));
      text-align: left;
      box-shadow: 0 20px 44px rgba(0,0,0,.28);
    }
    .carousel-card img {
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
    }
    .carousel-card div { padding: 16px; }
    .carousel-card h3 {
      text-transform: uppercase;
      font-size: .8rem;
      letter-spacing: .04em;
    }
    .carousel-card p {
      margin-top: 8px;
      color: var(--muted);
      font-size: .82rem;
    }
    .carousel-btn {
      position: absolute;
      top: 50%;
      width: 40px;
      height: 40px;
      border: 1px solid rgba(255,255,255,.18);
      border-radius: 50%;
      background: rgba(0,0,0,.72);
      color: #fff;
      transform: translateY(-50%);
      cursor: pointer;
      z-index: 2;
    }
    .carousel-btn:hover { border-color: var(--red); color: var(--red); }
    .carousel-btn.prev { left: -12px; }
    .carousel-btn.next { right: -12px; }
    .carousel-dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 16px;
    }
    .carousel-dot {
      width: 8px;
      height: 8px;
      border: 0;
      border-radius: 50% !important;
      background: rgba(255,255,255,.35);
      cursor: pointer;
    }
    .carousel-dot.is-active { background: var(--red); }

    .split {
      display: grid;
      grid-template-columns: minmax(0, .78fr) minmax(340px, .62fr);
      gap: 34px;
      align-items: start;
    }
    .capabilities {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .capability {
      padding: 16px;
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }
    .capability svg {
      width: 18px;
      height: 18px;
      color: var(--red);
      flex: 0 0 auto;
      margin-top: 3px;
    }
    .comparison {
      border: 1px solid var(--line-red);
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--panel);
    }
    .comparison-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--line);
    }
    .comparison-row:last-child { border-bottom: 0; }
    .comparison-row div { padding: 14px; }
    .comparison-head { background: var(--red); font-weight: 800; text-transform: uppercase; letter-spacing: .04em; font-size: .78rem; }
    .comparison-row div:first-child:not(.comparison-head) { color: var(--muted); }

    .logo-wall {
      overflow: hidden;
      border-block: 1px solid var(--line);
      background: rgba(255,255,255,.04);
    }
    .logo-track {
      width: max-content;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 0;
      animation: logoMove 34s linear infinite;
    }
    .logo-box {
      width: 148px;
      height: 62px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 6px;
      background: rgba(255,255,255,.88);
      padding: 12px;
    }
    .logo-box img { max-height: 34px; max-width: 120px; object-fit: contain; }
    @keyframes logoMove { to { transform: translateX(-50%); } }

    .client-section {
      position: relative;
      padding: 10px 0 74px;
      overflow: hidden;
      background: #000;
    }
    .client-bg-art {
      position: absolute;
      right: -5%;
      bottom: -22%;
      width: min(980px, 72vw);
      opacity: .72;
      pointer-events: none;
      z-index: 2;
    }
    .client-section .container {
      position: relative;
      z-index: 3;
    }
    .logo-wall.glass {
      width: 100%;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.26);
      border-radius: 8px;
      background: rgba(255,255,255,.07);
      backdrop-filter: blur(18px);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 24px 70px rgba(0,0,0,.38);
    }
    .logo-wall.glass .logo-track {
      padding: 28px 0;
    }
    .logo-wall.glass .logo-box {
      width: 190px;
      height: 86px;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 8px;
      background: rgba(255,255,255,.78);
      opacity: .86;
      filter: grayscale(.95) contrast(1.02);
      transition: opacity .2s ease, filter .2s ease, transform .2s ease;
    }
    .logo-wall.glass .logo-box:hover {
      opacity: 1;
      filter: grayscale(.05) brightness(1.04);
      transform: translateY(-2px);
    }
    .logo-wall.glass .logo-box img {
      max-width: 158px;
      max-height: 52px;
    }

    .visit-steps {
      counter-reset: step;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 12px;
    }
    .visit-step {
      padding: 18px;
      min-height: 184px;
      position: relative;
    }
    .visit-step::before {
      counter-increment: step;
      content: "0" counter(step);
      display: block;
      color: var(--red);
      font-size: 1.55rem;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 16px;
    }
    .visit-step p { color: var(--muted); margin-top: 10px; font-size: .82rem; }

    .map-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 30px;
      align-items: center;
    }
    .map-wrap img {
      width: 100%;
      max-height: 520px;
      object-fit: contain;
      filter: drop-shadow(0 20px 50px rgba(234,45,45,.12));
    }
    .presence-list { display: grid; gap: 10px; }
    .presence-chip { padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .presence-chip span { color: var(--red); font-weight: 800; }

    .presence-map-section {
      min-height: clamp(760px, 100vh, 980px);
      padding: 10px 0 56px;
      background: #000;
      overflow: hidden;
    }
    .presence-map-section h2 {
      max-width: none;
      margin: 0;
      font-size: 1.4rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0;
    }
    .global-map-stage {
      position: relative;
      min-height: clamp(600px, calc(100vh - 180px), 780px);
      display: grid;
      place-items: center;
    }
    .global-map-stage img {
      width: 100%;
      max-width: 1700px;
      max-height: 720px;
      object-fit: contain;
      filter: drop-shadow(0 24px 60px rgba(0,0,0,.62));
    }
    .map-legend {
      position: absolute;
      right: 22px;
      bottom: 16px;
      display: grid;
      gap: 10px;
      font-size: .64rem;
      font-weight: 800;
      text-transform: uppercase;
    }
    .legend-dot,
    .legend-flag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #fff;
    }
    .legend-dot::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--red);
    }
    .legend-partners {
      display: grid;
      gap: 4px;
      margin-top: 8px;
    }
    .legend-flag img {
      width: 26px;
      height: 17px;
      object-fit: cover;
      border-radius: 2px;
      border: 1px solid rgba(255,255,255,.18);
    }

    .contact {
      padding: 10px 0 86px;
    }
    .contact-panel {
      padding: 28px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 24px;
      align-items: center;
      background:
        linear-gradient(90deg, rgba(0,0,0,.84), rgba(0,0,0,.58) 48%, rgba(0,0,0,.86)),
        url("https://onepws.com/wp-content/uploads/2026/04/Rectangle-43.png") center/cover no-repeat,
        linear-gradient(110deg, rgba(234,45,45,.16), rgba(255,255,255,.04) 44%, rgba(54,169,255,.08)),
        #070707;
    }
    .footer {
      border-top: 1px solid var(--line);
      padding: 28px 0;
      color: var(--muted);
      font-size: .8rem;
    }
    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }
    .footer img { width: 96px; }

    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity .6s ease, transform .6s ease;
    }
    .reveal.is-visible { opacity: 1; transform: translateY(0); }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: .01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: .01ms !important;
      }
      .reveal { opacity: 1; transform: none; }
    }

    @media (max-width: 1020px) {
      h1 { font-size: 2.3rem; }
      h2 { font-size: 1.75rem; }
      .nav-inner { min-height: 78px; }
      .brand img:first-child { width: 158px; }
      .brand img:last-child { width: 100px; }
      .nav-links, .nav-stats { display: none; }
      .event-status { min-width: 190px; }
      .menu-toggle { display: grid; }
      .mobile-open .nav-links {
        position: absolute;
        left: 0;
        right: 0;
        top: calc(100% + 10px);
        display: grid;
        gap: 0;
        background: rgba(6,6,6,.97);
        border: 1px solid var(--line);
        border-radius: 8px;
        box-shadow: var(--shadow);
      }
      .mobile-open .nav-links a { padding: 15px; border-bottom: 1px solid var(--line); }
      .mobile-open .nav-links a:last-child { border-bottom: 0; }
      .hero-grid, .split, .section-head, .map-wrap, .contact-panel { grid-template-columns: 1fr; }
      .hero { padding-top: 108px; min-height: 740px; }
      .event-schedule .schedule-stack { width: 90%; }
      .facts, .proof-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .scenarios, .showcase-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .showcase-feature-row { grid-template-columns: 1fr; }
      .showcase-feature { grid-template-columns: 76px minmax(0, 1fr) minmax(130px, .7fr); }
      .scale-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .carousel-slide { flex-basis: 50%; }
      .global-map-stage { min-height: 560px; }
      .global-map-stage img { width: 100%; }
      .visit-steps { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 640px) {
      body { font-size: 14px; }
      .container { width: 100%; padding-inline: 14px; }
      .section { padding: 10px 0 48px; }
      h1 { font-size: 1.62rem; max-width: 340px; }
      h2 { font-size: 1.45rem; }
      .hero-copy .lead { max-width: none; }
      .brand { flex: 1 1 auto; justify-content: flex-start; gap: 10px; }
      .brand img:first-child { width: 122px; }
      .brand img:last-child { width: 76px; }
      .nav-inner { min-height: 74px; flex-wrap: nowrap; justify-content: space-between; gap: 12px; padding-block: 8px; }
      .nav-actions { width: auto; justify-content: flex-end; gap: 8px; }
      .nav-actions .btn-primary,
      .nav-actions .btn-secondary { display: none; }
      .event-status { min-width: unset; padding: 5px 8px; }
      .event-status .event-status-label { display: none; }
      .event-status.is-live .event-status-label,
      .event-status.is-expired .event-status-label { display: block; font-size: .72rem; }
      .event-status .countdown-grid { grid-template-columns: repeat(2, 1fr); gap: 3px; }
      .event-status .countdown-grid span:nth-child(3),
      .event-status .countdown-grid span:nth-child(4) { display: none; }
      .event-status .countdown-grid span { font-size: .78rem; }
      .event-status .countdown-grid small { font-size: .42rem; }
      .mobile-open .nav-links { left: 0; right: 0; }
      .hero { padding-top: 96px; min-height: 650px; }
      .hero::before {
        background:
          linear-gradient(180deg, rgba(0,0,0,.94) 0%, rgba(0,0,0,.72) 44%, rgba(0,0,0,.9) 100%),
          linear-gradient(90deg, rgba(0,0,0,.88), rgba(0,0,0,.4));
      }
      .hero-slide { background-position: 72% center; opacity: .72; }
      .hero-grid { gap: 22px; }
      .hero-copy h1 { max-width: none; }
      .hero-meta, .facts, .proof-grid, .scale-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .scenarios, .showcase-grid, .capabilities, .visit-steps { grid-template-columns: 1fr; }
      .hero-cta, .contact-panel > div:last-child { display: grid; width: 100%; }
      .btn { width: 100%; white-space: normal; }
      .comparison-row { grid-template-columns: 1fr; }
      .comparison-row div:first-child:not(.comparison-head) { border-bottom: 1px solid var(--line); }
      .schedule-title h2,
      .conference-head h2 { font-size: 1.55rem; }
      .event-schedule .schedule-stack { width: 90%; padding-inline: 0; }
      .day-item { grid-template-columns: 42px minmax(0, 1fr); gap: 12px; }
      .day-icon { width: 34px; height: 34px; }
      .day-icon-divider { width: 34px; height: 58px; }
      .day-line { grid-template-columns: 1fr; gap: 2px; }
      .conference-table-wrap { overflow-x: auto; }
      .conference-table { min-width: 760px; }
      .workshop-card { padding: 24px; min-height: 300px; }
      .showcase-feature { grid-template-columns: 58px minmax(0, 1fr); padding: 16px; }
      .showcase-feature img { grid-column: 1 / -1; height: 150px; }
      .showcase-feature strong { font-size: 2.45rem; }
      .showcase-feature h3 { font-size: 1.05rem; }
      .showcase-reference,
      .client-section,
      .contact { padding-top: 10px; }
      .showcase-reference { padding-bottom: 48px; }
      .showcase-header { margin-bottom: 24px; }
      .showcase-header h2 { font-size: 1.45rem; }
      .showcase-header p { font-size: .76rem; }
      .why-panel { padding-top: 42px; }
      .tag { font-size: 1.05rem; min-height: 40px; }
      .why-panel h2 { font-size: .9rem; }
      .carousel-slide { flex-basis: 100%; }
      .carousel-viewport { margin-inline: 0; }
      .carousel-btn.prev { left: 6px; }
      .carousel-btn.next { right: 6px; }
      .client-bg-art { width: 110vw; right: -30%; bottom: -8%; opacity: .5; }
      .presence-map-section { min-height: auto; padding-top: 64px; }
      .global-map-stage { min-height: 430px; }
      .map-legend { position: static; margin-top: 18px; justify-self: center; text-align: left; }
      .legend-partners { grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 10px; }
      .legend-flag { font-size: .72rem; gap: 8px; }
      .legend-flag img { width: 30px; height: 20px; }
      .logo-box { width: 126px; height: 56px; }
      .showcase-stat-strip { grid-template-columns: repeat(3, 1fr); }
      .showcase-stat-strip-item { padding: 20px 12px 16px; border-radius: 12px; gap: 10px; }
      .showcase-stat-strip-item strong { font-size: 1.4rem; }
      .showcase-stat-icon { width: 40px; height: 40px; }
      .showcase-stat-icon svg { width: 36px; height: 36px; }
    }

    /* ── Expo Strip Section ──────────────────────────────────────── */
    .expo-strip-section {
      padding: 0 0 20px;
    }
    .expo-strip-section .showcase-stat-strip {
      margin-bottom: 0;
    }

    /* ── Video Showcase Section ─────────────────────────────────────── */
    .video-showcase {
      padding: 52px 0 64px;
      background: #000;
    }
    .video-wrap {
      position: relative;
      width: 100%;
      border-radius: 14px;
      overflow: hidden;
      cursor: pointer;
      background: #060606;
      aspect-ratio: 16 / 9;
      border: 1px solid rgba(234,45,45,.22);
      box-shadow: 0 0 60px rgba(234,45,45,.1), 0 30px 80px rgba(0,0,0,.6);
    }
    .showcase-video {
      width: 100%; height: 100%;
      object-fit: cover; display: block; outline: none;
    }
    .video-click-hint {
      position: absolute; inset: 0;
      display: flex; align-items: flex-end; justify-content: center;
      padding-bottom: 28px;
      background: linear-gradient(transparent 55%, rgba(0,0,0,.55));
      pointer-events: none;
      transition: opacity .4s ease;
    }
    .video-click-hint.hidden { opacity: 0; pointer-events: none; }
    .video-hint-pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 9px 18px;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 999px;
      background: rgba(0,0,0,.6);
      color: rgba(255,255,255,.88);
      font-size: .72rem; font-weight: 700;
      letter-spacing: .05em; text-transform: uppercase;
      backdrop-filter: blur(8px);
    }
    .video-hint-pill svg { width: 18px; height: 18px; flex-shrink: 0; }
    .video-section-head {
      text-align: center;
      margin-bottom: 28px;
    }
    .video-section-head .eyebrow {
      font-size: 1rem;
      letter-spacing: .06em;
    }
    .video-section-head .eyebrow::before {
      width: 42px;
    }
    @media (max-width: 640px) {
      .video-showcase { padding-bottom: 48px; }
      .video-wrap { border-radius: 8px; }
    }
  </style>
</head>
<body>
  <header class="nav" id="top">
    <div class="container nav-inner">
      <div class="brand">
        <a href="https://onepws.com/" target="_blank" rel="noopener" aria-label="OnePWS">
          <img src="https://onepws.com/wp-content/uploads/2024/12/onepws-logo-2.png" alt="OnePWS">
        </a>
        <a href="https://www.automationindiaexpo.com/" target="_blank" rel="noopener" aria-label="Automation Expo 2026">
          <img src="https://onepws.com/wp-content/uploads/2026/06/logo.png" alt="Automation Expo 2026">
        </a>
      </div>
      <nav class="nav-links" aria-label="Primary navigation">
