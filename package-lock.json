  <script>
    const nav = document.querySelector(".nav");
    const menuButton = document.querySelector(".menu-toggle");

    menuButton.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("mobile-open");
      menuButton.setAttribute("aria-expanded", String(isOpen));
      menuButton.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    });

    document.querySelectorAll(".nav-links a").forEach((link) => {
      link.addEventListener("click", () => {
        nav.classList.remove("mobile-open");
        menuButton.setAttribute("aria-expanded", "false");
        menuButton.setAttribute("aria-label", "Open menu");
      });
    });

    const eventStatus = document.querySelector("[data-event-status]");
    const eventStart = new Date("2026-07-22T10:00:00+05:30");
    const eventEnd = new Date("2026-07-25T18:00:00+05:30");

    const pad = (value) => String(value).padStart(2, "0");

    const updateEventStatus = () => {
      if (!eventStatus) return;

      const now = new Date();
      const label = eventStatus.querySelector(".event-status-label");
      const countdown = eventStatus.querySelector("[data-countdown]");

      eventStatus.classList.remove("is-live", "is-expired");

      if (now >= eventStart && now <= eventEnd) {
        eventStatus.classList.add("is-live");
        label.textContent = "Live Now";
        return;
      }

      if (now > eventEnd) {
        eventStatus.classList.add("is-expired");
        label.textContent = "Expired";
        return;
      }

      label.textContent = "Event Starts In";
      const diff = eventStart - now;
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);

      countdown.querySelector("[data-days]").textContent = pad(days);
      countdown.querySelector("[data-hours]").textContent = pad(hours);
      countdown.querySelector("[data-minutes]").textContent = pad(minutes);
      countdown.querySelector("[data-seconds]").textContent = pad(seconds);
    };

    updateEventStatus();
    window.setInterval(updateEventStatus, 1000);

    document.querySelectorAll(".elementor-carousel").forEach((carousel) => {
      const track = carousel.querySelector(".carousel-track");
      const slides = Array.from(carousel.querySelectorAll(".carousel-slide"));
      const prev = carousel.querySelector(".carousel-btn.prev");
      const next = carousel.querySelector(".carousel-btn.next");
      const dotsWrap = carousel.querySelector(".carousel-dots");
      let index = 0;
      let visible = 3;
      let timer;
      let isPaused = false;

      const getVisible = () => {
        const basis = slides[0].getBoundingClientRect().width || 1;
        const viewport = carousel.querySelector(".carousel-viewport").getBoundingClientRect().width || basis;
        return Math.max(1, Math.round(viewport / basis));
      };

      const renderDots = () => {
        dotsWrap.innerHTML = "";
        const pages = Math.max(1, slides.length - visible + 1);
        for (let i = 0; i < pages; i += 1) {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "carousel-dot";
          dot.setAttribute("aria-label", `Go to showcase slide ${i + 1}`);
          dot.addEventListener("click", () => {
            index = i;
            update();
            stop();
          });
          dotsWrap.appendChild(dot);
        }
      };

      const update = () => {
        visible = getVisible();
        const max = Math.max(0, slides.length - visible);
        index = Math.min(Math.max(index, 0), max);
        const slideWidth = slides[0].getBoundingClientRect().width;
        track.style.transform = `translateX(${-index * slideWidth}px)`;
        Array.from(dotsWrap.children).forEach((dot, i) => {
          dot.classList.toggle("is-active", i === index);
        });
      };

      const restart = () => {
        if (isPaused) return;
        window.clearInterval(timer);
        timer = window.setInterval(() => {
          const max = Math.max(0, slides.length - visible);
          index = index >= max ? 0 : index + 1;
          update();
        }, 4200);
      };

      const stop = () => {
        isPaused = true;
        window.clearInterval(timer);
      };

      prev.addEventListener("click", () => {
        const max = Math.max(0, slides.length - visible);
        index = index <= 0 ? max : index - 1;
        update();
        stop();
      });

      next.addEventListener("click", () => {
        const max = Math.max(0, slides.length - visible);
        index = index >= max ? 0 : index + 1;
        update();
        stop();
      });

      carousel.addEventListener("pointerdown", stop);

      window.addEventListener("resize", () => {
        visible = getVisible();
        renderDots();
        update();
      });

      visible = getVisible();
      renderDots();
      update();
      restart();
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.14 });

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));


    // Video: click to reveal controls
    const showcaseVideo = document.getElementById('showcaseVideo');
    const videoHint = document.getElementById('videoHint');
    const videoWrap = document.getElementById('videoWrap');
    if (showcaseVideo && videoWrap) {
      let controlsVisible = false;
      videoWrap.addEventListener('click', () => {
        if (!controlsVisible) {
          controlsVisible = true;
          showcaseVideo.setAttribute('controls', '');
          if (videoHint) videoHint.classList.add('hidden');
        }
      });
      videoWrap.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          videoWrap.click();
        }
      });
    }

    // Active nav link highlight on scroll
    const navAnchors = document.querySelectorAll(".nav-links a[href^='#']");
    const scrollSections = document.querySelectorAll("section[id]");
    const highlightNav = () => {
      let current = "";
      scrollSections.forEach(sec => {
        if (sec.getBoundingClientRect().top <= 150) current = sec.id;
      });
      navAnchors.forEach(a => {
        a.classList.toggle("is-active", a.getAttribute("href") === "#" + current);
      });
    };
    window.addEventListener("scroll", highlightNav, { passive: true });
    highlightNav();
  </script>
